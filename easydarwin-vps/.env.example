# EasyDarwin VPS 环境变量配置

# 域名配置（必须修改）
DOMAIN=your-domain.com

# 邮件通知配置（可选，用于监控告警）
NOTIFICATION_EMAIL=admin@your-domain.com
SMTP_SERVER=smtp.gmail.com:587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# 基础配置
TZ=Asia/Shanghai
LOG_LEVEL=warn
ENVIRONMENT=production

# EasyDarwin 镜像配置
EASYDARWIN_IMAGE=cakeor/easydarwin:latest
EASYDARWIN_VERSION=v8.3.3

# 资源限制配置
CPU_LIMIT=2.0
MEMORY_LIMIT=1G
CPU_RESERVATION=0.5
MEMORY_RESERVATION=256M

# 日志配置
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5

# 安全配置
# 设置为 true 启用推流认证
RTMP_AUTH_ENABLE=false
RTSP_AUTH_ENABLE=false

# 推流认证信息（如果启用认证）
STREAM_USERNAME=streamer
STREAM_PASSWORD=your-stream-password

# 管理员认证
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-admin-password

# 数据库配置（可选）
DB_TYPE=sqlite
DB_PATH=/app/data/easydarwin.db

# 录像配置
RECORD_ENABLE=false
RECORD_PATH=/app/records
RECORD_FORMAT=mp4

# WebRTC 配置
WEBRTC_ENABLE=true
ICE_SERVERS=stun:stun.l.google.com:19302

# HLS 配置
HLS_ENABLE=true
HLS_SEGMENT_DURATION=10
HLS_SEGMENT_COUNT=3

# 监控配置
WATCHTOWER_ENABLE=true
LOGROTATE_ENABLE=true

# 备份配置
BACKUP_RETENTION_DAYS=7
AUTO_BACKUP_ENABLE=false
BACKUP_SCHEDULE="0 2 * * 0"  # 每周日凌晨2点

# CDN 配置（可选）
CDN_ENABLE=false
CDN_DOMAIN=cdn.your-domain.com

# 防盗链配置（可选）
HOTLINK_PROTECTION=false
ALLOWED_DOMAINS=your-domain.com,*.your-domain.com