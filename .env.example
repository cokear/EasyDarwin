# EasyDarwin Docker Compose 环境变量配置

# 基础配置
COMPOSE_PROJECT_NAME=easydarwin
TZ=Asia/Shanghai

# 镜像配置
EASYDARWIN_IMAGE=cakeor/easydarwin:latest
EASYDARWIN_VERSION=v8.3.3

# 端口配置
WEB_PORT=8080
RTSP_PORT=554
RTMP_PORT=1935
WEBRTC_SIGNAL_PORT=4433
WEBRTC_MEDIA_PORT=5544
API_PORT=8083
API_EXT_PORT=8084
OTHER_PORT=1290

# UDP端口范围
RTP_PORT_START=30000
RTP_PORT_END=30100
UDP_PORT_1=6001
UDP_PORT_2=4888

# 日志配置
LOG_LEVEL=info
LOG_MAX_SIZE=10m
LOG_MAX_FILES=3

# 资源限制
CPU_LIMIT=2.0
MEMORY_LIMIT=1G
CPU_RESERVATION=0.5
MEMORY_RESERVATION=256M

# 数据目录
DATA_DIR=./data
CONFIG_DIR=./data/configs
LOG_DIR=./data/logs
WEB_DIR=./data/web

# Nginx配置（生产环境）
NGINX_PORT=80
NGINX_SSL_PORT=443
NGINX_CONFIG_DIR=./nginx

# Redis配置（开发环境）
REDIS_PORT=6379

# 监控工具端口（开发环境）
PORTAINER_PORT=9000
DOZZLE_PORT=9999

# 健康检查配置
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=10s
HEALTH_CHECK_RETRIES=3
HEALTH_CHECK_START_PERIOD=40s

# 网络配置
NETWORK_SUBNET=172.20.0.0/16

# 安全配置
# DOCKER_REGISTRY_USER=your_username
# DOCKER_REGISTRY_PASS=your_password